{
  "$schema": "https://design-tokens.org/schema",
  "meta": {
    "name": "Tati Ribeiro Design System",
    "version": "1.0.0",
    "description": "Design tokens da marca pessoal Tati Ribeiro — Futurismo Restrito. Base monocromática + único acento roxo herdado da Entrelaços.",
    "author": "Tati Ribeiro",
    "lastUpdate": "2026-04"
  },

  "color": {
    "heritage": {
      "purple":         { "value": "#6B46C1", "comment": "Roxo Entrelaços — único acento" },
      "purple-light":   { "value": "#8B5CF6" },
      "purple-deep":    { "value": "#2E1065" },
      "purple-glow":    { "value": "#A78BFA" },
      "purple-circuit": { "value": "#4C1D95" }
    },
    "mono": {
      "void":       { "value": "#050505" },
      "black":      { "value": "#0A0A0A" },
      "onyx":       { "value": "#0F0F14" },
      "charcoal":   { "value": "#14141A" },
      "graphite":   { "value": "#1C1C25" },
      "stone":      { "value": "#262631" },
      "iron":       { "value": "#33333F" },
      "ash":        { "value": "#45454F" },
      "fog":        { "value": "#6B6B7A" },
      "mist":       { "value": "#8E8E9A" },
      "paper":      { "value": "#C4C4CC" },
      "bone":       { "value": "#E0E0E5" },
      "warm-white": { "value": "#F5F4F0" },
      "ivory":      { "value": "#FAFAF7" },
      "pearl":      { "value": "#FFFFFE" }
    },
    "accent": {
      "default": { "value": "{color.heritage.purple}" },
      "light":   { "value": "{color.heritage.purple-light}" },
      "glow":    { "value": "{color.heritage.purple-glow}" },
      "deep":    { "value": "{color.heritage.purple-circuit}" },
      "bg":      { "value": "rgba(139, 92, 246, 0.06)" },
      "border":  { "value": "rgba(139, 92, 246, 0.18)" }
    }
  },

  "gradient": {
    "mono":   { "value": "linear-gradient(180deg, #050505 0%, #14141A 100%)" },
    "accent": { "value": "linear-gradient(135deg, #4C1D95 0%, #6B46C1 50%, #8B5CF6 100%)" },
    "text":   { "value": "linear-gradient(135deg, #2E1065 0%, #6B46C1 35%, #8B5CF6 70%, #A78BFA 100%)" },
    "glow":   { "value": "radial-gradient(ellipse at center, rgba(107,70,193,0.18) 0%, transparent 60%)" }
  },

  "font": {
    "family": {
      "display": { "value": "'Inter', -apple-system, BlinkMacSystemFont, sans-serif", "comment": "Estrutura — autoridade silenciosa" },
      "serif":   { "value": "'Source Serif 4', Georgia, serif", "comment": "Alma — italic acolhe" },
      "body":    { "value": "'Inter', -apple-system, sans-serif" },
      "mono":    { "value": "'JetBrains Mono', 'SF Mono', Menlo, monospace", "comment": "Sistema — sinalização sutil de IA" }
    },
    "weight": {
      "ultralight": { "value": "200" },
      "light":      { "value": "300" },
      "regular":    { "value": "400" },
      "medium":     { "value": "500" },
      "semibold":   { "value": "600" },
      "bold":       { "value": "700" }
    },
    "size": {
      "xs":   { "value": "11px" },
      "sm":   { "value": "13px" },
      "base": { "value": "15px" },
      "md":   { "value": "17px" },
      "lg":   { "value": "21px" },
      "xl":   { "value": "26px" },
      "2xl":  { "value": "32px" },
      "3xl":  { "value": "40px" },
      "4xl":  { "value": "52px" },
      "5xl":  { "value": "76px" },
      "display": { "value": "clamp(64px, 10.5vw, 152px)" }
    },
    "tracking": {
      "tighter": { "value": "-0.05em" },
      "tight":   { "value": "-0.03em" },
      "normal":  { "value": "0" },
      "wide":    { "value": "0.1em" },
      "wider":   { "value": "0.2em" },
      "widest":  { "value": "0.3em" }
    },
    "leading": {
      "none":    { "value": "1" },
      "tight":   { "value": "1.1" },
      "snug":    { "value": "1.3" },
      "normal":  { "value": "1.5" },
      "relaxed": { "value": "1.65" },
      "loose":   { "value": "1.7" }
    }
  },

  "space": {
    "2xs": { "value": "2px" },
    "xs":  { "value": "4px" },
    "sm":  { "value": "8px" },
    "md":  { "value": "16px" },
    "lg":  { "value": "24px" },
    "xl":  { "value": "32px" },
    "2xl": { "value": "48px" },
    "3xl": { "value": "64px" },
    "4xl": { "value": "96px" },
    "5xl": { "value": "128px" },
    "6xl": { "value": "192px" }
  },

  "radius": {
    "xs":   { "value": "2px" },
    "sm":   { "value": "4px" },
    "md":   { "value": "8px" },
    "lg":   { "value": "12px" },
    "xl":   { "value": "16px" },
    "2xl":  { "value": "24px" },
    "full": { "value": "9999px" }
  },

  "shadow": {
    "sm":     { "value": "0 1px 2px rgba(0,0,0,0.08)" },
    "md":     { "value": "0 4px 12px rgba(0,0,0,0.15)" },
    "lg":     { "value": "0 12px 32px rgba(0,0,0,0.2)" },
    "purple": { "value": "0 12px 40px rgba(107,70,193,0.3)" },
    "glow":   { "value": "0 0 24px rgba(167,139,250,0.4)" }
  },

  "easing": {
    "default": { "value": "cubic-bezier(0.4, 0, 0.2, 1)" },
    "out":     { "value": "cubic-bezier(0.16, 1, 0.3, 1)" },
    "precise": { "value": "cubic-bezier(0.83, 0, 0.17, 1)" },
    "spring":  { "value": "cubic-bezier(0.34, 1.56, 0.64, 1)" }
  },

  "duration": {
    "instant": { "value": "150ms" },
    "fast":    { "value": "250ms" },
    "base":    { "value": "400ms" },
    "slow":    { "value": "600ms" },
    "slower":  { "value": "1000ms" }
  },

  "z": {
    "base":     { "value": "1" },
    "raised":   { "value": "10" },
    "dropdown": { "value": "100" },
    "sticky":   { "value": "200" },
    "modal":    { "value": "1000" },
    "toast":    { "value": "2000" }
  },

  "breakpoint": {
    "sm": { "value": "640px" },
    "md": { "value": "768px" },
    "lg": { "value": "1024px" },
    "xl": { "value": "1280px" },
    "2xl": { "value": "1536px" }
  }
}
