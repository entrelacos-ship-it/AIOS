# Required for Whisper transcription on Groq
GROQ_API_KEY=gsk_...

# Required to run Claude analysis through OpenRouter
OPENROUTER_API_KEY=sk-or-v1-...
CLAUDE_MODEL=anthropic/claude-3.5-sonnet

# Optional: used to generate scene illustrations in review mode
OPENAI_API_KEY=sk-...
OPENAI_IMAGE_MODEL=gpt-image-1

# Optional: explicit ffmpeg binaries on Windows/server
FFMPEG_PATH=
FFPROBE_PATH=

# Storage paths
UPLOAD_DIR=./uploads
OUTPUT_DIR=./outputs
